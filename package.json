{
  "name": "sui-next-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm --filter @paystreamer/portal dev\" \"pnpm --filter @paystreamer/checkout dev\" \"pnpm --filter docs dev\" \"docker compose up\"",
    "dev": "vite --port 5176 --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "codegen": "pnpm --filter @paystreamer/sdk codegen",
    "seed:demo": "pnpm --filter @paystreamer/sdk run seed:demo",
    "e2e": "bash ci/e2e.sh",
    "docs:dev": "pnpm --filter docs dev",
    "lint:no-fakes": "node ci/lint-no-fakes.mjs",
    "test": "./ci/verify-builds.sh",
    "test:all": "./ci/verify-builds.sh",
    "test:e2e": "cd apps/docs && npx playwright test",
    "test:move": "cd move && sui move test --coverage",
    "lint:move": "cd move && sui move build --lint",
    "test:sdk": "cd packages/sdk && npx vitest run",
    "test:docs": "cd apps/docs && npx vitest run"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@mysten/dapp-kit-core": "^1.6.8",
    "@mysten/dapp-kit-react": "^2.1.3",
    "@mysten/sui": "^2.19.0",
    "@mysten/utils": "^0.4.0",
    "@mysten/wallet-standard": "^0.21.8",
    "@nanostores/react": "^1.0.0",
    "@paystreamer/sdk": "workspace:*",
    "@protobuf-ts/grpc-transport": "^2.9.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^6.30.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@mysten/codegen": "^0.11.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^10.0.3",
    "prettier": "^3.7.4",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4.1.18",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.5"
  }
}
