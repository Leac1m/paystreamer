{
  "name": "@paystreamer/sdk",
  "version": "0.2.0",
  "description": "PayStreamer SDK for integrating recurring billing on Sui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paystreamer/paystreamer",
    "directory": "packages/sdk"
  },
  "keywords": [
    "sui",
    "paystreamer",
    "subscriptions",
    "recurring-payments",
    "sdk"
  ],
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "codegen": "rm -rf src/contracts && sui-ts-codegen generate",
    "build": "tsup src/index.ts src/core/index.ts src/react/index.ts src/ui/index.ts --format esm --external react --external react-dom --external react/jsx-runtime --no-splitting && tsc --emitDeclarationOnly",
    "dev": "tsup src/index.ts src/core/index.ts src/react/index.ts src/ui/index.ts --format esm --watch --external react --external react-dom --external react/jsx-runtime --no-splitting",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "seed:demo": "tsx scripts/seed-demo-platform.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@mysten/dapp-kit-react": "^2.1.3",
    "@mysten/sui": "^2.19.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.562.0",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@mysten/codegen": "^0.11.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.2.3",
    "typescript": "^5.5.3",
    "vitest": "^4.1.10"
  }
}
